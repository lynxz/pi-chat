# --- Dependencies ----------------------------------------------------------
# Node modules (both root and nested under extensions/)
node_modules/
**/node_modules/

# --- Build / cache ---------------------------------------------------------
# TS build output, coverage reports, cache dirs
dist/
build/
coverage/
.cache/
.turbo/
*.tsbuildinfo

# --- Logs / temp -----------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# --- Local env / secrets ---------------------------------------------------
# Never commit env files or credentials
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# --- IDE / editor ----------------------------------------------------------
.vscode/
.idea/
*.iml
.cursor/

# --- Project-specific: the design doc --------------------------------------
# pi-chat.md is an internal design / planning document. It is not part of
# the public repo. Anyone who wants the protocol write-up can read it
# directly in the source tree or generate docs from the code.
pi-chat.md

# --- OS / runtime artifacts -----------------------------------------------
# Leftover from `npm start`, `docker compose`, etc.
*.pid
*.sock
core.*